#!/bin/bash
# FLEETCOM: single front-door command. Dispatches a subcommand to the matching
# fleetcom-<name>.sh script (which still work when run directly — they call each
# other by name), and provides built-in man-style help:
#   fleetcom help | man            overview of every command
#   fleetcom <command>             run that command
#   fleetcom <command> --help      help for that one command
set -euo pipefail

# Resolve $0 through symlinks so HERE is the repo dir even when fleetcom is run
# via a symlink on PATH (e.g. /opt/homebrew/bin/fleetcom -> the repo). Plain
# `dirname "$0"` would give the symlink's dir, and delegating subcommands would
# then look for fleetcom-<x>.sh in the wrong place. (Portable — no readlink -f.)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
	dir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
	SOURCE="$(readlink "$SOURCE")"
	case "$SOURCE" in /*) ;; *) SOURCE="$dir/$SOURCE" ;; esac
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# --- formatting: bold section headers on a TTY, plain when piped -------------
if [ -t 1 ]; then
	B="$(tput bold 2>/dev/null || true)"; N="$(tput sgr0 2>/dev/null || true)"
else
	B=""; N=""
fi
h() { printf '%s%s%s\n' "$B" "$1" "$N"; }
# page long help through less on a TTY (‑F: don't page if it fits one screen);
# plain cat when piped/redirected, so `fleetcom help | cat` stays clean.
page() { if [ -t 1 ] && command -v less >/dev/null 2>&1; then less -RF; else cat; fi; }

render_version() {
	local v
	v="$(git -C "$HERE" describe --tags --always --dirty 2>/dev/null || true)"
	[ -n "$v" ] || v="unknown"
	printf 'fleetcom %s\n' "$v"
}

render_overview() {
	h "FLEETCOM"
	printf 'Run the Midship, Cascade, and AuditBoard stacks side-by-side, locally.\n\n'
	h "Usage:"
	printf '  fleetcom <command> [options]\n\n'
	h "Commands:"
	printf '  %-10s %s\n' onboard "Configure repositories, ports, SSO, and dependencies"
	printf '  %-10s %s\n' start   "Start all stacks in dependency order"
	printf '  %-10s %s\n' stop    "Stop Cascade + AuditBoard (--midship for Midship too)"
	printf '  %-10s %s\n' restart "Restart the entire stack, Midship included"
	printf '  %-10s %s\n' doctor  "Show port + health status"
	printf '  %-10s %s\n' logs    "Stream backend logs and error alerts"
	printf '  %-10s %s\n' claude  "Full restart, then launch Claude Code beside the logs"
	printf '\n'
	h "Global options:"
	printf '  %-15s %s\n' "-h, --help"    "Show help"
	printf '  %-15s %s\n' "-v, --version" "Show version"
	printf '\n'
	printf "Run 'fleetcom <command> --help' for command-specific help.\n"
}

# Per-command man-style page. Sections: NAME / USAGE / DESCRIPTION / OPTIONS
# (only where the command takes any) / NOTES (only where useful) / EXAMPLES.
render_cmd_help() {
	case "$1" in
	onboard)
		h "NAME";        printf '    fleetcom onboard - one-time, idempotent setup of the local stacks\n\n'
		h "USAGE";       printf '    fleetcom onboard [--reconfigure]\n\n'
		h "DESCRIPTION"; printf '    Applies all port-deconfliction and SSO config so Midship, Cascade,\n    and AuditBoard run side-by-side: repository paths, env files, secrets,\n    dependency installs, Hatchet, and (confirmed) database seeding. Safe to\n    run multiple times.\n\n'
		h "OPTIONS"
		printf '    --reconfigure\n        Re-prompt for repository locations, rewriting local.conf.\n\n'
		h "NOTES"
		printf '    First-time setup should also seed the AuditBoard database — see\n    "Database seeding" in the README. At the end, offers to put the\n    fleetcom command on your PATH.\n\n'
		h "EXAMPLES"
		printf '    fleetcom onboard\n    fleetcom onboard --reconfigure\n'
		;;
	start)
		h "NAME";        printf '    fleetcom start - boot the whole stack in dependency order\n\n'
		h "USAGE";       printf '    fleetcom start [--no-logs] [--tmux | --windows]\n\n'
		h "DESCRIPTION"; printf '    Starts Midship, AuditBoard, and Cascade, skipping anything already\n    running (each port is checked first). Ends by opening the log view in\n    your saved LOGS_VIEW preference.\n\n'
		h "OPTIONS"
		printf '    --no-logs\n        Do not auto-open the log panes after starting.\n'
		printf '    --tmux\n        Open the logs in the tmux grid for this run (not persisted).\n'
		printf '    --windows\n        Open the logs in separate Terminal windows for this run (not persisted).\n\n'
		h "EXAMPLES"
		printf '    fleetcom start\n    fleetcom start --tmux\n    fleetcom start --no-logs\n'
		;;
	stop)
		h "NAME";        printf '    fleetcom stop - stop Cascade and AuditBoard\n\n'
		h "USAGE";       printf '    fleetcom stop [--midship]\n\n'
		h "DESCRIPTION"; printf '    Stops Cascade and AuditBoard and tears down the log view. Midship is\n    left running (the shared, fixed stack) unless --midship is given.\n\n'
		h "OPTIONS"
		printf '    --midship\n        Also stop the Midship stack.\n\n'
		h "EXAMPLES"
		printf '    fleetcom stop\n    fleetcom stop --midship\n'
		;;
	restart)
		h "NAME";        printf '    fleetcom restart - full bounce of everything, Midship included\n\n'
		h "USAGE";       printf '    fleetcom restart [--no-logs] [--tmux | --windows]\n\n'
		h "DESCRIPTION"; printf '    Runs "stop --midship" then "start": a clean restart of all three\n    stacks. Any options are forwarded to start.\n\n'
		h "OPTIONS"
		printf '    --no-logs\n        Do not auto-open the log panes after restarting.\n'
		printf '    --tmux\n        Open the logs in the tmux grid for this run (not persisted).\n'
		printf '    --windows\n        Open the logs in separate Terminal windows for this run (not persisted).\n\n'
		h "EXAMPLES"
		printf '    fleetcom restart\n    fleetcom restart --windows\n'
		;;
	doctor)
		h "NAME";        printf '    fleetcom doctor - port and health status report\n\n'
		h "USAGE";       printf '    fleetcom doctor\n\n'
		h "DESCRIPTION"; printf '    Checks that every expected port is held by the expected process (or\n    free) and runs basic HTTP health checks. Read-only and safe to run any\n    time. Exits non-zero if any check fails.\n\n'
		h "EXAMPLES"
		printf '    fleetcom doctor\n'
		;;
	logs)
		h "NAME";        printf '    fleetcom logs - stream backend logs and error alerts\n\n'
		h "USAGE";       printf '    fleetcom logs [--tmux | --windows | --kill]\n\n'
		h "DESCRIPTION"; printf '    Opens five live streams (optro-api, midship-api, cascade, alerts,\n    doctor) as a tmux grid or as separate Terminal windows. The first run\n    asks which you prefer and remembers it. Ctrl-C in a pane drops you into\n    a shell in that repo.\n\n'
		h "OPTIONS"
		printf '    --tmux\n        Switch to the tmux grid (persisted to local.conf).\n'
		printf '    --windows\n        Switch to separate Terminal windows (persisted to local.conf).\n'
		printf '    --kill\n        Tear down the tmux session / close the log windows.\n\n'
		h "EXAMPLES"
		printf '    fleetcom logs\n    fleetcom logs --windows\n    fleetcom logs --kill\n'
		;;
	claude|start-claude)
		h "NAME";        printf '    fleetcom claude - full restart, then a Claude Code pane by the logs\n\n'
		h "USAGE";       printf '    fleetcom claude [--midship] [--no-restart]\n\n'
		h "DESCRIPTION"; printf '    Does a full restart, then adds a Claude Code pane to the tmux log\n    window (Claude on the left, logs tiled on the right). Claude reads log\n    output on demand rather than tailing continuously.\n\n'
		h "OPTIONS"
		printf '    --midship\n        Also stop/restart Midship during the bounce.\n'
		printf '    --no-restart\n        Skip the stop/start; just add the Claude pane to a running session.\n\n'
		h "NOTES"
		printf '    Requires the claude CLI. tmux is preferred (Claude tiled beside the\n    logs); if it is missing you are offered a "brew install tmux", and\n    declining falls back to separate Terminal windows with Claude in this\n    terminal. Run it from a separate terminal window, not from inside the\n    log session (the restart tears that down).\n\n'
		h "EXAMPLES"
		printf '    fleetcom claude\n    fleetcom claude --no-restart\n'
		;;
	*)
		printf 'fleetcom: no help for %s\n' "$1" >&2
		return 1
		;;
	esac
}

sub="${1:-help}"
[ $# -ge 1 ] && shift || true

# global: version, then overview (bare `fleetcom`, help, man, -h, --help)
case "$sub" in
	-v|--version|version) render_version; exit 0 ;;
	help|man|-h|--help|"") render_overview | page; exit 0 ;;
esac

# subcommand -> script
case "$sub" in
	onboard)             script=fleetcom-onboard.sh ;;
	start)               script=fleetcom-start-all.sh ;;
	stop)                script=fleetcom-stop-all.sh ;;
	restart)             script=fleetcom-restart-all.sh ;;
	doctor)              script=fleetcom-doctor.sh ;;
	logs)                script=fleetcom-logs.sh ;;
	claude|start-claude) script=fleetcom-start-claude.sh ;;
	*)
		printf 'fleetcom: unknown command "%s"\n\n' "$sub" >&2
		printf 'usage: fleetcom <command> [options]   (try: fleetcom help)\n' >&2
		exit 2
		;;
esac

# `fleetcom <command> --help/-h` prints that command's help instead of running it
for a in "$@"; do
	case "$a" in
		-h|--help) render_cmd_help "$sub" | page; exit 0 ;;
	esac
done

exec "$HERE/$script" "$@"
