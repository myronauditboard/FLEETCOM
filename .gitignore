# Runtime output from fleetcom-start-all.sh — API/client logs can contain tokens,
# session cookies, and query payloads. Never commit.
logs/
*.log

# Per-machine repo locations written by fleetcom-onboard.sh's prompts.
local.conf

# Belt-and-braces: no env files in this repo, ever. Secrets live in the
# per-machine files fleetcom-onboard.sh writes to (auditboard-dev-env/.envrc,
# cascade/.env), both gitignored in their own repos.
.env
.env.*
